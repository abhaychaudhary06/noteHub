<%- include('partials/header') %>
<div class="app-layout">
  <aside class="sidebar">
    <a href="/dashboard" class="sidebar-link"><span>🏠</span> Dashboard</a>
    <a href="/notes" class="sidebar-link active"><span>📝</span> Notes</a>
    <a href="/notes/add" class="sidebar-link"><span>➕</span> Add Note</a>
    <a href="/profile" class="sidebar-link"><span>👤</span> Profile</a>
  </aside>

  <main class="page-content">
    <a href="/notes" class="back-link">← Back to notes</a>
    <h1 class="page-title">Edit Note</h1>

    <div class="form-card" style="margin-top:20px">
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <!-- PUT method ke liye ?_method=PUT -->
      <form action="/notes/edit/<%= note._id %>?_method=PUT" method="POST">
        <div class="form-group">
          <label>Title</label>
          <!-- value= se purana data prefill hoga -->
          <input type="text" name="title" value="<%= note.title %>" required>
        </div>
        <div class="form-group">
          <label>Category</label>
          <select name="category">
            <% ['Ideas','Learning','Backend','Personal','Other'].forEach(cat => { %>
              <option value="<%= cat %>" <%= note.category === cat ? 'selected' : '' %>>
                <%= cat %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Content</label>
          <textarea name="content" required><%= note.content %></textarea>
        </div>
        <button type="submit" class="btn-primary">Update Note</button>
      </form>
    </div>
  </main>
</div>
<%- include('partials/footer') %>